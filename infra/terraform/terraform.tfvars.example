aws_region  = "ap-northeast-2"
domain_name = "example.com"
route53_zone_id = ""
manage_route53_zone = false
admin_cidr  = "203.0.113.10/32"

db_name             = "ostone"
db_master_username  = "ostone_admin"
db_master_password  = "replace-with-secure-master-password"
app_db_password     = "replace-with-secure-app-password"
airflow_db_password = "replace-with-secure-airflow-password"
jwt_secret          = "replace-with-secure-jwt-secret"
airflow_api_username = "admin"
airflow_api_password = "replace-with-secure-airflow-api-password"
airflow_api_base_url = "http://<airflow-private-ip>:8080"
airflow_api_allow_insecure_http = true
airflow_webhook_secret = "replace-with-secure-webhook-secret"

backend_desired_count = 0
backend_autoscaling_min_capacity = 0
backend_autoscaling_max_capacity = 3

gpu_instance_type          = "g6.2xlarge"
gpu_asg_min_size           = 0
gpu_asg_max_size           = 1
gpu_asg_desired_capacity   = 0
gpu_root_volume_size       = 120
embedding_model_name       = "BAAI/bge-m3"
embedding_model_cache_mount_path = "/app/.cache/huggingface"
ml_runtime_profile         = "balanced"
llm_model_name             = "google/gemma-4-E4B-it"
llm_model_path             = "/models/gemma-4-E4B-it.gguf"
llm_service_desired_count  = 0
llm_service_container_port = 8000
llm_runtime_api_key        = ""

ai_embedding_provider                          = "bedrock"
ai_embedding_model                             = "cohere.embed-v4:0"
ai_embedding_bedrock_region                    = "ap-northeast-2"
ai_chat_bedrock_region                         = "ap-northeast-2"
ai_chat_bedrock_model                          = "anthropic.claude-sonnet-4-6"
ai_embedding_enabled                           = true
ai_embedding_timeout_seconds                   = 5
ai_embedding_profile_build_running_timeout     = "15m"
ai_embedding_auto_run_replay_fitness_threshold = 0.70
ai_embedding_confident_threshold               = 0.72
ai_embedding_ambiguous_threshold               = 0.55
ai_embedding_confident_margin                  = 0.10
ai_embedding_semantic_floor                    = 0.65
ai_embedding_route_evidence_floor              = 0.50
ai_embedding_lexical_evidence_floor            = 0.30

cors_allowed_origins = [
  "https://airflow.example.com",
  "https://app.example.com"
]

secret_arns = []
