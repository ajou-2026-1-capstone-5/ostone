# 라이브 스모크 e2e 환경변수 예시
# 이 파일을 frontend/.env.e2e.local로 복사해 실제 값을 채운다.
# .env.e2e.local은 gitignore되며 실제 자격증명은 절대 커밋하지 않는다.
# 라이브 스모크는 운영/배포 백엔드를 실제로 호출하므로 로컬에서 수동으로만 실행한다(CI 금지).
#
# 실행 예시:
#   pnpm exec playwright test --config=playwright.live.config.ts

# 대상 배포 URL. 브라우저가 이 주소를 열고, 빌드타임 설정에 따라 해당 환경의 백엔드 API를 사용한다.
E2E_BASE_URL=https://example.invalid

# 운영(app.ajou-cstone.com) 대상 오실행 방지 확인값.
# 대상이 운영 host일 때만 필요하며, 운영 host 문자열과 정확히 일치해야 통과한다.
# 운영 대상이 아니면 비워둬도 된다.
E2E_CONFIRM_PROD=

# 로그인 자격증명. 테스트 전용 계정 사용을 권장한다.
E2E_EMAIL=replace-with-test-account@example.invalid
E2E_PASSWORD=replace-with-test-account-password

# 운영 데이터에 쓰기(워크스페이스 생성 등)를 수행하는 spec 허용 여부.
# "true"일 때만 활성화되며, 그 외에는 데이터 오염 방지를 위해 읽기/검증 위주로 동작한다.
E2E_ALLOW_POLLUTING=false
