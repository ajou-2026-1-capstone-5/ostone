AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${AIRFLOW_DB_USER}:${AIRFLOW_DB_PASSWORD}@postgres:5432/${AIRFLOW_DB_NAME}
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN_ASYNC=postgresql+asyncpg://${AIRFLOW_DB_USER}:${AIRFLOW_DB_PASSWORD}@postgres:5432/${AIRFLOW_DB_NAME}
# Generate with: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
# Keep this private and rotate it if the local auth/token state is reset.
AIRFLOW__CORE__FERNET_KEY=ilPjQSBqt-pN_Ci6T-DDa5PQFIfEvGBdc-jiv0StvLk=
# Generate with: `openssl rand -hex 32` or use a password manager-generated secret.
# Keep this private and rotate it if shared accidentally.
AIRFLOW__API__SECRET_KEY=init-airflow-api-secret-key
# Generate with: `openssl rand -hex 32` or use a password manager-generated secret.
# Keep this private and rotate it with the API secret as needed.
AIRFLOW__API_AUTH__JWT_SECRET=init-airflow-jwt-secret-key
AIRFLOW__API__BASE_URL=http://airflow-apiserver:8080
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-apiserver:8080/execution/
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin,viewer:viewer
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_PASSWORDS_FILE=/opt/airflow/auth/simple_auth_manager_passwords.json.generated
AIRFLOW_SIMPLE_ADMIN_PASSWORD=admin
AIRFLOW_SIMPLE_VIEWER_PASSWORD=viewer
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
PYTHONPATH=/opt/airflow/src
PIPELINE_BACKEND_BASE_URL=http://backend:8080
PIPELINE_ARTIFACT_ROOT=/opt/airflow/artifacts
