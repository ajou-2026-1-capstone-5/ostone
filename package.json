{
  "name": "ajou-2026-1-capstone-5",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm for root dependencies. Run: corepack enable && pnpm install'); process.exit(1)}\"",
    "prepare": "husky",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "vitest": "^4.1.2"
  }
}
