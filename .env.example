DB_NAME=init
DB_PASSWORD=init-db-password
DB_USER=init
SPRING_PROFILE=local
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false

# AI Provider (OpenAI 호환 프로토콜)
# Gemini(기본)와 OpenAI 모두 동일한 OpenAI 호환 endpoint 로 동작한다.
# 제공자 전환은 아래 AI_* 변수만 교체하면 된다.
#   - Gemini : AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#              AI_CHAT_MODEL=gemini-2.5-flash-lite
#   - OpenAI : AI_BASE_URL=https://api.openai.com
#              AI_CHAT_MODEL=gpt-4o-mini
AI_API_KEY=
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_CHAT_MODEL=gemini-2.5-flash-lite
# AI_CHAT_TEMPERATURE=0.7
# AI_CHAT_AUTO_RESPONSE_CORE_SIZE=4
# AI_CHAT_AUTO_RESPONSE_MAX_SIZE=8
# AI_CHAT_AUTO_RESPONSE_QUEUE_CAPACITY=16
# AI_CHAT_AUTO_RESPONSE_KEEP_ALIVE_SECONDS=60

# MinIO (local only)
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ROOT_USER=minioadmin

# Storage (S3 / MinIO)
#
# [모드 A] MinIO — 기본값. 아래 변수를 .env에서 완전히 제거(또는 주석 처리)하면
#   docker-compose 기본값(MinIO)이 적용된다.
#   MinIO 버킷은 최초 1회 수동 생성 필요:
#     docker compose exec minio mc alias set local http://localhost:9000 minioadmin minioadmin
#     docker compose exec minio mc mb local/init-raw-files-dev
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_BUCKET=init-raw-files-dev
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_PATH_STYLE=
# STORAGE_S3_REGION=ap-northeast-2
# STORAGE_S3_SECRET_KEY=
#
# [모드 B] 실제 AWS S3 — SSO 기반 (별도 credentials 파일 / IAM key 미사용).
#   사전 1회: ~/.aws/config 에 [profile ostone] SSO 프로필 설정
#            (.agent/docs/aws-sso-setup.md 1~3절 참조)
#
#   매 세션마다:
#     1) aws sso login --profile ostone
#     2) eval "$(aws configure export-credentials --profile ostone --format env)"
#        → 호스트 셸에 AWS_ACCESS_KEY_ID / SECRET_ACCESS_KEY / SESSION_TOKEN 주입
#     3) 같은 셸에서 docker compose up -d
#        → docker-compose 가 컨테이너로 AWS_* 환경변수 passthrough
#
#   STORAGE_S3_* 4 변수(ACCESS_KEY / SECRET_KEY / ENDPOINT / PATH_STYLE)는
#   모두 빈 값이어야 한다. 값이 채워져 있으면 StaticCredentialsProvider 가 먼저
#   잡혀 SSO 임시 자격증명이 무시된다.
#
#   .env 또는 셸에서 다음과 같이 설정한다 (운영 버킷명은 팀 운영 채널 확인):
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_BUCKET=<S3_PROD_BUCKET>
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_PATH_STYLE=
# STORAGE_S3_REGION=ap-northeast-2
# STORAGE_S3_SECRET_KEY=
#
#   토큰 만료 시 위 1~2단계 재실행 후 docker compose restart backend.
#   상세는 .agent/docs/aws-sso-setup.md 4-bis 절 참조.

AIRFLOW_API_BASE_URL=http://airflow-apiserver:8080
AIRFLOW_API_CONNECT_TIMEOUT=3s
AIRFLOW_API_PASSWORD=admin
AIRFLOW_API_READ_TIMEOUT=10s
AIRFLOW_API_USERNAME=admin
AIRFLOW_DOMAIN_PACK_GENERATION_DAG_ID=domain_pack_generation
AIRFLOW_SIMPLE_ADMIN_PASSWORD=admin
AIRFLOW_SIMPLE_VIEWER_PASSWORD=viewer
AIRFLOW_UID=50000
AIRFLOW_WEBHOOK_SECRET=change-me-airflow-webhook-secret
AIRFLOW__API_AUTH__JWT_SECRET=init-airflow-jwt-secret-key
AIRFLOW__API__SECRET_KEY=init-airflow-api-secret-key
AIRFLOW__CORE__FERNET_KEY=ilPjQSBqt-pN_Ci6T-DDa5PQFIfEvGBdc-jiv0StvLk=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
JWT_SECRET=<your-jwt-secret-at-least-32-bytes-long>
PIPELINE_ARTIFACT_ROOT=/opt/airflow/artifacts
PIPELINE_BACKEND_BASE_URL=http://backend:8080
PIPELINE_CALLBACK_ENABLED=true
PIPELINE_CALLBACK_TIMEOUT_SECONDS=10
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MAX_LENGTH=1024
HF_HOME=/opt/airflow/.cache/huggingface
PIPELINE_TASK_TIMEOUT_MINUTES=90
# Optional Mac host-native embedding worker. Run the host worker with
# `cd ml && uv run python -m pipeline.local_embedder_server`, then start compose
# with `-f docker-compose.yml -f ml/docker-compose.local-embedder.yml`.
LOCAL_EMBEDDER_BASE_URL=http://host.docker.internal:18090
EMBEDDING_RUNTIME_TIMEOUT_SECONDS=1800
PIPELINE_DAG_MAX_ACTIVE_RUNS=4
PIPELINE_DAG_MAX_ACTIVE_TASKS=1
PIPELINE_CLUSTERING_SELECTION_MAX_INPUTS=5000
AIRFLOW_CORE_PARALLELISM=1
PIPELINE_KNN_K=12
PIPELINE_NUM_THREADS=4
PIPELINE_KNN_N_JOBS=4
PIPELINE_KNN_PROJECTION_MIN_INPUTS=5000
PIPELINE_KNN_PROJECTION_DIMS=8
PIPELINE_KNN_BATCH_SIZE=2048
PIPELINE_KNN_WINDOW_MIN_INPUTS=5000
PIPELINE_KNN_WINDOW_SIZE=48
PIPELINE_HDBSCAN_MAX_INPUTS=5000
PIPELINE_STABILITY_MAX_INPUTS=5000
# Optional shared Hugging Face cache. Mount EFS on the host and run compose with
# ml/docker-compose.model-cache.yml to use this path. Without the override, the
# model is downloaded into the container runtime cache.
# AIRFLOW_MODEL_CACHE_PATH=/mnt/ostone-model-cache/huggingface

# dev 배포용 환경변수
# 애플리케이션 런타임 환경변수는 Render Dashboard 또는 Blueprint(render.yaml)에서 설정
# GitHub Secrets는 GitHub Actions 배포 워크플로우에서 Render API 호출 등에만 사용되며, Render 컨테이너에 직접 주입되지 않음
# CORS_ALLOWED_ORIGINS=https://<render-frontend-url>  # Render에서 직접 설정하세요
SERVER_PORT=10000
SPRING_DATASOURCE_PASSWORD=<neon-password>
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>:5432/<dbname>?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-username>
SPRING_PROFILES_ACTIVE=dev
VITE_API_BASE_URL=https://<render-backend-url>/api/v1
VITE_WS_URL=wss://<render-backend-url>
