DB_NAME=init
DB_USER=init
DB_PASSWORD=change-me
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_PASSWORD=change-me
SPRING_PROFILE=local

# MinIO (local only)
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ROOT_USER=minioadmin

# Storage (S3 / MinIO)
# local: 아래 값 그대로 사용 (application-local.yml이 오버라이드)
# dev/prod: 실제 AWS 버킷명·리전·IAM 키로 교체
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_BUCKET=init-raw-files-dev
STORAGE_S3_ENDPOINT=
STORAGE_S3_PATH_STYLE=false
STORAGE_S3_REGION=ap-northeast-2
STORAGE_S3_SECRET_KEY=
JWT_SECRET=change-me-at-least-32-characters-long
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=<generate-a-valid-fernet-key>
AIRFLOW__API__SECRET_KEY=change-me
AIRFLOW__API_AUTH__JWT_SECRET=change-me
AIRFLOW_SIMPLE_ADMIN_PASSWORD=change-me-admin
AIRFLOW_SIMPLE_VIEWER_PASSWORD=change-me-viewer
PIPELINE_BACKEND_BASE_URL=http://backend:8080
PIPELINE_ARTIFACT_ROOT=/opt/airflow/artifacts
